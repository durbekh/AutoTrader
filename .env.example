# =============================================================================
# AutoTrader - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# NEVER commit the .env file to version control.

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=autotrader
POSTGRES_USER=autotrader
POSTGRES_PASSWORD=autotrader_secret
DATABASE_URL=postgres://autotrader:autotrader_secret@db:5432/autotrader

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Elasticsearch
# -----------------------------------------------------------------------------
ELASTICSEARCH_URL=http://elasticsearch:9200

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@autotrader.com
EMAIL_HOST_PASSWORD=your-email-password

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost/api/v1

# -----------------------------------------------------------------------------
# VIN Decoder API (NHTSA)
# -----------------------------------------------------------------------------
VIN_API_URL=https://vpic.nhtsa.dot.gov/api/vehicles/DecodeVinValues

# -----------------------------------------------------------------------------
# File Storage
# -----------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
MEDIA_ROOT=/app/media
STATIC_ROOT=/app/staticfiles

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
